{
  "name": "@samuraizer/mcp-server",
  "version": "0.1.3",
  "type": "module",
  "license": "MIT",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "bin": {
    "samuraizer-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "postbuild": "chmod +x dist/index.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@samuraizer/cli": "^0.4.0",
    "memnex-spec": "^0.2.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.6.2",
    "typescript": "^5.9.3",
    "vitest": "^4.1.5"
  }
}
