{
    "compilerOptions": {
        "target": "es2022",
        "module": "nodenext",
        "moduleResolution": "nodenext",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "noEmit": true,
        "types": ["node"],
        "forceConsistentCasingInFileNames": true,
        "allowImportingTsExtensions": false
    },
    "include": ["scripts/**/*.ts"]
}