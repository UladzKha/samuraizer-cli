{
    "name": "@samuraizer/schema",
    "version": "0.1.0",
    "description": "Open JSON Schema for portable meeting outputs (transcripts, summaries, action items, decisions)",
    "license": "MIT",
    "author": "Uladz Kha <UladzKha@users.noreply.github.com>",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/UladzKha/samuraizer-cli.git",
        "directory": "packages/schema"
    },
    "homepage": "https://github.com/UladzKha/samuraizer-cli/tree/main/packages/schema#readme",
    "bugs": {
        "url": "https://github.com/UladzKha/samuraizer-cli/issues"
    },
    "keywords": [
        "json-schema",
        "meeting",
        "transcript",
        "interoperability",
        "open-standard",
        "local-first"
    ],
    "files": [
        "spec",
        "README.md",
        "LICENSE",
        "dist"
    ],
    "exports": {
        ".": {
            "default": "./spec/meeting-output.schema.json"
        },
        "./types":{
            "types" : "./dist/types.d.ts"
        },
        "./schema": {
            "default": "./spec/meeting-output.schema.json"
        },
        "./examples/minimal": {
            "default": "./spec/examples/minimal.json"
        },
        "./examples/full": {
            "default": "./spec/examples/full.json"
        }
    },
    "scripts": {
        "build": "node scripts/build-types.mjs",
        "typecheck": "tsc --noEmit",
        "prepublishOnly": "npm run build"
    },
    "engines": {
        "node": ">=20"
    },
    "devDependencies": {
        "json-schema-to-typescript": "^15.0.4"
    }
}