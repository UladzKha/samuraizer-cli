{
  "name": "@samuraizer/cli",
  "version": "0.2.0",
  "type": "module",
  "bin": {
    "samuraizer": "./dist/cli/index.js"
  },
  "scripts": {
    "dev": "tsx src/cli/index.ts",
    "process": "tsx src/cli/index.ts process",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "prepack": "npm run build",
    "prepublishOnly": "npm run typecheck && npm run build"
  },
  "exports": {
    "./shared/tool-definition": {
      "types": "./dist/shared/tool-definition.d.ts",
      "import": "./dist/shared/tool-definition.js",
      "default": "./dist/shared/tool-definition.js"
    },
    "./shared/tool-registry": {
      "types": "./dist/shared/tool-registry.d.ts",
      "import": "./dist/shared/tool-registry.js",
      "default": "./dist/shared/tool-registry.js"
    },
    "./tools/context": {
      "types": "./dist/tools/context.d.ts",
      "import": "./dist/tools/context.js",
      "default": "./dist/tools/context.js"
    },
    "./orchestrators/process-meeting": {
      "types": "./dist/orchestrators/process-meeting.d.ts",
      "import": "./dist/orchestrators/process-meeting.js",
      "default": "./dist/orchestrators/process-meeting.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "transcription",
    "meeting-notes",
    "whisper",
    "ollama",
    "local-llm",
    "speech-to-text",
    "cli",
    "self-hosted",
    "privacy"
  ],
  "license": "MIT",
  "description": "Local-first CLI that turns meeting recordings into transcripts, summaries, action items, and decisions",
  "author": "Uladz Kha <UladzKha@users.noreply.github.com>",
  "funding": "https://github.com/sponsors/UladzKha",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/UladzKha/samuraizer-cli.git"
  },
  "homepage": "https://github.com/UladzKha/samuraizer-cli#readme",
  "bugs": {
    "url": "https://github.com/UladzKha/samuraizer-cli/issues"
  },
  "dependencies": {
    "@samuraizer/schema": "^0.1.0",
    "commander": "^14.0.3",
    "execa": "^9.6.1",
    "ulid": "^2.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
