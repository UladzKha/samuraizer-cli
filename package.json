{
  "name": "samuraizer",
  "version": "0.0.1",
  "type": "module",
  "bin": {
    "samuraizer": "./dist/cli/index.js"
  },
  "scripts": {
    "dev": "tsx src/cli/index.ts",
    "process": "tsx src/cli/index.ts process",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "prepack": "npm run build"
  },
  "files": [
