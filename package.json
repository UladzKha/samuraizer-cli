  "repository": {
    "type": "git",
    "url": "https://github.com/UladzKha/samuraizer-cli.git"
  },
  "homepage": "https://github.com/UladzKha/samuraizer-cli#readme",
  "bugs": {
    "url": "https://github.com/UladzKha/samuraizer-cli/issues"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "execa": "^9.6.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}